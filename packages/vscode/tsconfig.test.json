{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2024",
    "lib": ["ES2024"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "outDir": "tests-dist",
    "sourceMap": true,
    "strict": true,
    "rootDir": "tests",
    "skipLibCheck": true
  },
  "include": ["./tests/suite", "./tests/runTest.ts"],
  "exclude": [
    "./rslib.config.mts",
    "./rstest.config.mts",
    "./src",
    "./sample",
    "./tests/unit",
    "./tests/fixtures"
  ]
}
