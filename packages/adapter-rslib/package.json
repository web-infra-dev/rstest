{
  "name": "@rstest/adapter-rslib",
  "version": "0.2.2",
  "description": "Rstest adapter for rslib configuration",
  "keywords": [
    "rstest",
    "rslib",
    "adapter",
    "configuration"
  ],
  "bugs": {
    "url": "https://github.com/web-infra-dev/rstest/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/web-infra-dev/rstest",
    "directory": "packages/adapter-rslib"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "test": "rstest",
    "typecheck": "pnpm -w exec tsc --noEmit -p packages/adapter-rslib/tsconfig.json"
  },
  "devDependencies": {
    "@rslib/core": "0.21.0",
    "@rstest/core": "workspace:*",
    "@rstest/tsconfig": "workspace:*",
    "tsconfck": "3.1.6",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "@rslib/core": ">=0.18.6",
    "@rstest/core": ">=0.7.7",
    "typescript": "^5 || ^6"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
