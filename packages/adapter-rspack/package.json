{
  "name": "@rstest/adapter-rspack",
  "version": "0.2.0",
  "description": "Rstest adapter for rspack configuration",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "test": "rstest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "rstest",
    "rspack",
    "adapter",
    "configuration"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@rspack/cli": ">=2.0.0-0",
    "@rspack/core": ">=2.0.0-0",
    "@rstest/core": ">=0.7.7"
  },
  "devDependencies": {
    "@rspack/cli": "2.0.0-canary-20260116",
    "@rspack/core": "2.0.0-beta.6",
    "@rslib/core": "0.20.0",
    "@rstest/core": "workspace:*",
    "@rstest/tsconfig": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/web-infra-dev/rstest/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/web-infra-dev/rstest",
    "directory": "packages/adapter-rspack"
  }
}
