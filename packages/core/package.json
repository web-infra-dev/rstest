{
  "name": "@rstest/core",
  "version": "0.9.9",
  "description": "The Rsbuild-based test tool.",
  "keywords": [
    "rstest",
    "test",
    "rstack",
    "rspack"
  ],
  "bugs": {
    "url": "https://github.com/web-infra-dev/rstest/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/web-infra-dev/rstest",
    "directory": "packages/core"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    },
    "./browser-runtime": {
      "types": "./dist/browser-runtime/index.d.ts",
      "default": "./dist/browser-runtime/index.js"
    },
    "./package.json": {
      "default": "./package.json"
    },
    "./globals": {
      "types": "./globals.d.ts"
    },
    "./importMeta": {
      "types": "./importMeta.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "rstest": "./bin/rstest.js"
  },
  "files": [
    "bin",
    "dist",
    "compiled",
    "globals.d.ts",
    "importMeta.d.ts"
  ],
  "scripts": {
    "build": "rslib build && npx prettier ./LICENSE.md --write",
    "dev": "cross-env SOURCEMAP=true rslib build --watch",
    "test": "npx rstest --globals",
    "typecheck": "pnpm -w exec tsc --noEmit -p packages/core/tsconfig.json"
  },
  "dependencies": {
    "@rsbuild/core": "^2.0.0",
    "@types/chai": "^5.2.3",
    "tinypool": "^2.1.0"
  },
  "devDependencies": {
    "@babel/code-frame": "^7.29.0",
    "@clack/prompts": "^1.2.0",
    "@jridgewell/trace-mapping": "0.3.31",
    "@microsoft/api-extractor": "^7.58.2",
    "@rsbuild/plugin-less": "^1.6.2",
    "@rsbuild/plugin-node-polyfill": "^1.4.4",
    "@rsbuild/plugin-sass": "^1.5.1",
    "@rslib/core": "0.21.0",
    "@rstest/tsconfig": "workspace:*",
    "@sinonjs/fake-timers": "^15.3.2",
    "@types/babel__code-frame": "^7.27.0",
    "@types/istanbul-lib-coverage": "^2.0.6",
    "@types/istanbul-lib-report": "^3.0.3",
    "@types/istanbul-reports": "^3.0.4",
    "@types/jsdom": "^21.1.7",
    "@types/picomatch": "^4.0.3",
    "@types/source-map-support": "^0.5.10",
    "@typescript/native-preview": "7.0.0-dev.20260412.1",
    "@vitest/expect": "^3.2.4",
    "@vitest/pretty-format": "^3.2.4",
    "@vitest/snapshot": "^3.2.4",
    "@vitest/utils": "^3.2.4",
    "birpc": "^4.0.0",
    "cac": "^7.0.0",
    "chai": "^6.2.2",
    "chokidar": "^5.0.0",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.2",
    "memfs": "^4.57.1",
    "package-manager-detector": "^1.6.0",
    "pathe": "^2.0.3",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.4",
    "rslog": "^2.1.1",
    "source-map-support": "^0.5.21",
    "stacktrace-parser": "0.1.11",
    "std-env": "^4.0.0",
    "strip-ansi": "^7.2.0",
    "tinyglobby": "^0.2.16",
    "tinyspy": "^4.0.4",
    "url-extras": "^0.1.0",
    "webpack": "^5.106.1",
    "webpack-license-plugin": "^4.5.1"
  },
  "peerDependencies": {
    "happy-dom": "^20.8.3",
    "jsdom": "*"
  },
  "peerDependenciesMeta": {
    "happy-dom": {
      "optional": true
    },
    "jsdom": {
      "optional": true
    }
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
