{
  "type": "object",
  "properties": {
    "runner": {
      "type": "object",
      "properties": {
        "cmd": {
          "type": "string"
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cwd": {
          "type": "string"
        },
        "env": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": ["cmd", "args", "cwd"]
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "sourcePath": {
            "type": "string"
          },
          "line": {
            "type": "integer",
            "minimum": 1
          },
          "column": {
            "type": "integer",
            "minimum": 0
          },
          "expressions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "hitLimit": {
            "type": "integer",
            "minimum": 1
          },
          "condition": {
            "type": "string"
          },
          "order": {
            "type": "integer"
          },
          "hits": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": ["sourcePath", "line"]
      },
      "minItems": 1
    }
  },
  "required": ["runner", "tasks"],
  "$schema": "http://json-schema.org/draft-07/schema#"
}
